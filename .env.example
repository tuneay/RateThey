# RateThey environment variables.
# Copy this file to `.env` and fill in your Supabase project values.
# Supabase dashboard → Project Settings → (API) and (Database → Connection string).

# --- Supabase API ---
NEXT_PUBLIC_SUPABASE_URL="https://YOUR-PROJECT-REF.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
# Server-only. Full access — never expose to the client.
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# --- Database (Prisma) ---
# Pooled connection (Transaction pooler, port 6543) — used by the app at runtime.
DATABASE_URL="postgresql://postgres.YOUR-PROJECT-REF:YOUR-DB-PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres"
# Direct connection (port 5432) — used for migrations.
DIRECT_URL="postgresql://postgres.YOUR-PROJECT-REF:YOUR-DB-PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres"
